<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Reset Your Password - Hamsoya</title>
    <!--[if mso]>
      <noscript>
        <xml>
          <o:OfficeDocumentSettings>
            <o:PixelsPerInch>96</o:PixelsPerInch>
          </o:OfficeDocumentSettings>
        </xml>
      </noscript>
    <![endif]-->
    <style>
      /* Reset styles */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.6;
        color: #333333;
        background-color: #ececec;
        margin: 0;
        padding: 0;
        width: 100% !important;
        min-width: 100%;
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      /* Email client specific styles */
      table {
        border-collapse: collapse;
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }

      img {
        border: 0;
        height: auto;
        line-height: 100%;
        outline: none;
        text-decoration: none;
        -ms-interpolation-mode: bicubic;
      }

      /* Container styles */
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ececec;
        position: relative;
        overflow: hidden;
      }

      /* Background layers */
      .background-layer {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
      }

      .gradient-primary {
        background: linear-gradient(180deg, #ff6925 0%, #fff 46.48%);
        filter: blur(50px);
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 2;
      }

      .gradient-secondary {
        background: linear-gradient(
          180deg,
          #4d5de9 11.31%,
          rgba(255, 255, 255, 0) 46.48%
        );
        filter: blur(50px);
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 3;
      }

      .layer-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 4;
        opacity: 0.8;
      }

      /* Content wrapper */
      .content-wrapper {
        position: relative;
        z-index: 5;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 20px;
        margin: 40px 20px;
        padding: 40px 30px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      /* Header styles */
      .header {
        text-align: center;
        margin-bottom: 30px;
        padding: 20px 0;
      }

      .logo {
        font-size: 32px;
        font-weight: bold;
        background: linear-gradient(135deg, #ff6925 0%, #4d5de9 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 8px;
        letter-spacing: 1px;
      }

      .tagline {
        color: #666666;
        font-size: 16px;
        font-weight: 300;
      }

      /* Main content styles */
      .main-title {
        font-size: 28px;
        font-weight: bold;
        color: #333333;
        text-align: center;
        margin-bottom: 20px;
        line-height: 1.3;
      }

      .subtitle {
        font-size: 16px;
        color: #666666;
        text-align: center;
        margin-bottom: 30px;
        line-height: 1.6;
      }

      /* OTP Code styles */
      .otp-container {
        background: linear-gradient(135deg, #ff6925 0%, #4d5de9 100%);
        border-radius: 15px;
        padding: 30px;
        text-align: center;
        margin: 30px 0;
        box-shadow: 0 10px 30px rgba(255, 105, 37, 0.3);
        position: relative;
        overflow: hidden;
      }

      .otp-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(
          45deg,
          transparent 30%,
          rgba(255, 255, 255, 0.1) 50%,
          transparent 70%
        );
        animation: shimmer 2s infinite;
      }

      @keyframes shimmer {
        0% {
          transform: translateX(-100%);
        }
        100% {
          transform: translateX(100%);
        }
      }

      .otp-label {
        color: rgba(255, 255, 255, 0.9);
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
        position: relative;
        z-index: 2;
      }

      .otp-code {
        font-size: 36px;
        font-weight: bold;
        color: #ffffff;
        letter-spacing: 8px;
        margin: 15px 0;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        font-family: 'Courier New', monospace;
        position: relative;
        z-index: 2;
      }

      .otp-expiry {
        color: rgba(255, 255, 255, 0.8);
        font-size: 14px;
        margin-top: 10px;
        position: relative;
        z-index: 2;
      }

      /* Instructions styles */
      .instructions {
        background: rgba(248, 250, 252, 0.8);
        backdrop-filter: blur(10px);
        border-radius: 12px;
        padding: 25px;
        margin: 25px 0;
        border-left: 4px solid #ff6925;
      }

      .instructions h3 {
        color: #333333;
        font-size: 18px;
        margin-bottom: 15px;
        font-weight: 600;
      }

      .instructions ol {
        color: #555555;
        padding-left: 20px;
        line-height: 1.8;
      }

      .instructions li {
        margin-bottom: 8px;
        font-size: 15px;
      }

      /* Security notice styles */
      .security-notice {
        background: rgba(254, 242, 242, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(254, 202, 202, 0.5);
        border-radius: 12px;
        padding: 20px;
        margin: 25px 0;
        display: flex;
        align-items: flex-start;
        gap: 15px;
      }

      .security-notice .icon {
        font-size: 24px;
        flex-shrink: 0;
      }

      .security-notice p {
        color: #dc2626;
        font-size: 14px;
        line-height: 1.6;
        margin: 0;
      }

      /* Footer styles */
      .footer {
        text-align: center;
        padding-top: 30px;
        border-top: 1px solid rgba(229, 231, 235, 0.5);
        margin-top: 30px;
      }

      .footer p {
        color: #9ca3af;
        font-size: 13px;
        line-height: 1.6;
        margin-bottom: 10px;
      }

      .footer a {
        color: #ff6925;
        text-decoration: none;
      }

      .footer a:hover {
        text-decoration: underline;
      }

      /* Responsive styles */
      @media only screen and (max-width: 600px) {
        .content-wrapper {
          margin: 20px 10px;
          padding: 30px 20px;
        }

        .main-title {
          font-size: 24px;
        }

        .otp-code {
          font-size: 28px;
          letter-spacing: 4px;
        }

        .instructions {
          padding: 20px;
        }
      }

      /* Dark mode support */
      @media (prefers-color-scheme: dark) {
        .content-wrapper {
          background: rgba(31, 41, 55, 0.95) !important;
          color: #f9fafb !important;
        }

        .main-title {
          color: #ffffff !important;
        }

        .subtitle {
          color: #cccccc !important;
        }

        .instructions {
          background: rgba(40, 40, 40, 0.8) !important;
          color: #cccccc !important;
        }

        .instructions h3 {
          color: #ffffff !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="email-container">
      <!-- Background layers -->
      <div class="background-layer">
        <div class="gradient-primary"></div>
        <div class="gradient-secondary"></div>
        <img
          src="<%= process.env.BASE_URL || 'http://localhost:5001' %>/layer.jpg"
          alt=""
          class="layer-image"
        />
      </div>

      <!-- Main content -->
      <div class="content-wrapper">
        <!-- Header -->
        <div class="header">
          <div class="logo">Hamsoya</div>
          <div class="tagline">Your trusted marketplace</div>
        </div>

        <!-- Main content -->
        <h1 class="main-title">Reset Your Password</h1>
        <p class="subtitle">
          Hi <%= name %>,<br />
          We received a request to reset your password for your Hamsoya account.
          Use the verification code below to proceed with resetting your
          password.
        </p>

        <!-- OTP Code -->
        <div class="otp-container">
          <div class="otp-label">Your Password Reset Code</div>
          <div class="otp-code"><%= otp %></div>
          <div class="otp-expiry">This code expires in 5 minutes</div>
        </div>

        <!-- Instructions -->
        <div class="instructions">
          <h3>How to reset your password:</h3>
          <ol>
            <li>Copy the verification code above</li>
            <li>Return to the Hamsoya password reset page</li>
            <li>Enter the code in the verification field</li>
            <li>Create your new secure password</li>
          </ol>
        </div>

        <!-- Security notice -->
        <div class="security-notice">
          <div class="icon">🔒</div>
          <p>
            <strong>Security Notice:</strong> This password reset code is valid
            for 5 minutes only. If you didn't request this password reset,
            please ignore this email and your password will remain unchanged.
            For security concerns, contact our support team immediately.
          </p>
        </div>

        <!-- Footer -->
        <div class="footer">
          <p>
            This email was sent to you because a password reset was requested
            for your Hamsoya account. If you didn't make this request, please
            ignore this email.
          </p>
          <p>
            Need help? Contact us at
            <a href="mailto:support@hamsoya.com">support@hamsoya.com</a>
          </p>
          <p>© 2024 Hamsoya. All rights reserved.</p>
        </div>
      </div>
    </div>
  </body>
</html>
