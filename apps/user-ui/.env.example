# Server-side API Configuration (not exposed to client)
AUTH_SERVICE_URL=http://localhost:5000/api
AUTH_SERVICE_TIMEOUT=10000

# Security (required in production)
JWT_SECRET=your-jwt-secret-key
COOKIE_SECRET=your-cookie-secret-key

# Environment
NODE_ENV=development

# Client-side Configuration (exposed to client)
NEXT_PUBLIC_AUTH_TIMEOUT=10000
NEXT_PUBLIC_ENABLE_MOCK_API=false

# OTP Configuration
NEXT_PUBLIC_OTP_EXPIRY_MINUTES=5
NEXT_PUBLIC_OTP_RESEND_COOLDOWN_SECONDS=60

# Application Configuration
NEXT_PUBLIC_APP_NAME=Hamsoya
NEXT_PUBLIC_APP_URL=http://localhost:3000
